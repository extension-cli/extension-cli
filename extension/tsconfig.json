{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "types": ["chrome"]
  },
  "include": ["src", "entrypoints", "wxt.config.ts", "vite.config.ts"]
}
